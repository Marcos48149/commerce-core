{
  "name": "commerce-core",
  "private": true,
  "version": "0.1.0",
  "description": "CommerceCore MVP — Multi-tenant e-commerce platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @commerce/database db:generate",
    "db:push": "pnpm --filter @commerce/database db:push",
    "db:migrate": "pnpm --filter @commerce/database db:migrate",
    "db:seed": "pnpm --filter @commerce/database db:seed",
    "db:studio": "pnpm --filter @commerce/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
