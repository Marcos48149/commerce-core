generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext]
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REJECTED
  REFUNDED
  CANCELLED
}

enum PromotionType {
  PRODUCT_FIXED
  PRODUCT_PERCENTAGE
  CATEGORY_DISCOUNT
  CART_PERCENTAGE
  PAYMENT_METHOD_DISCOUNT
  COUPON
  BXGY
  AUTOMATIC_GIFT
}

enum WebhookEvent {
  order_created
  order_paid
  order_cancelled
  order_updated
  inventory_updated
  customer_created
}

// ─── TENANT & STORE ───────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  stores    Store[]
  webhooks  WebhookEndpoint[]
  auditLogs AuditLog[]
  plans     Plan[]
  admins    Admin[]
  roles     Role[]
}

model Plan {
  id            String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId      String   @db.VarChar(26)
  name          String   @db.VarChar(100)
  maxStores     Int      @default(1)
  maxAdmins     Int      @default(10)
  maxProducts   Int      @default(1000)
  maxWebhooks   Int      @default(10)
  features      Json     @default("{}")
  monthlyPrice  Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  stores Store[]

  @@index([tenantId])
}

model Store {
  id           String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId     String   @db.VarChar(26)
  planId       String?  @db.VarChar(26)
  name         String   @db.VarChar(255)
  slug         String   @db.VarChar(100)
  currency     String   @default("ARS") @db.VarChar(3)
  displayName  String?  @db.VarChar(255)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(50)
  address      String?  @db.Text
  logoUrl      String?  @db.VarChar(500)
  isActive     Boolean  @default(true)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  plan      Plan?           @relation(fields: [planId], references: [id])
  admins    Admin[]
  customers Customer[]
  products  Product[]
  carts     Cart[]
  orders    Order[]
  shippingMethods  ShippingMethod[]
  shippingZones    ShippingZone[]
  promotions       Promotion[]
  coupons          Coupon[]
  webhooks         WebhookEndpoint[]
  auditLogs        AuditLog[]
  templates        NotificationTemplate[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ─── BACKOFFICE IAM ───────────────────────────────────────────────────────────

model Admin {
  id            String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId      String   @db.VarChar(26)
  storeId       String?  @db.VarChar(26)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @db.VarChar(255)
  displayName   String   @db.VarChar(255)
  isSuperAdmin  Boolean  @default(false)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  refreshToken  String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  store     Store?      @relation(fields: [storeId], references: [id])
  roles     AdminRole[]
  auditLogs AuditLog[]
  apiKeys   ApiKey[]

  @@index([tenantId])
  @@index([storeId])
}

model ApiKey {
  id         String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId   String   @db.VarChar(26)
  storeId    String?  @db.VarChar(26)
  adminId    String   @db.VarChar(26)
  name       String   @db.VarChar(100)
  prefix     String   @db.VarChar(8)
  hash       String   @db.VarChar(255)
  scopes     Json     @default("[]")
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([prefix, hash])
  @@index([tenantId])
  @@index([storeId])
  @@index([adminId])
  @@index([prefix])
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId  String   @db.VarChar(26)
  name      String   @db.VarChar(100)
  scope     String   @default("store") @db.VarChar(20)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  admins    AdminRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  group       String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model AdminRole {
  adminId String
  roleId  String

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── CUSTOMER IDENTITY ────────────────────────────────────────────────────────

model Customer {
  id                String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId          String   @db.VarChar(26)
  storeId           String   @db.VarChar(26)
  email             String   @db.VarChar(255)
  passwordHash      String   @db.VarChar(255)
  displayName       String?  @db.VarChar(255)
  phone             String?  @db.VarChar(50)
  isActive          Boolean  @default(true)
  refreshToken      String?  @db.Text
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  store     Store     @relation(fields: [storeId], references: [id])
  addresses Address[]
  carts     Cart[]
  orders    Order[]

  @@unique([storeId, email])
  @@index([tenantId])
  @@index([storeId])
}

model Address {
  id         String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  customerId String   @db.VarChar(26)
  type       String   @default("shipping") @db.VarChar(20)
  line1      String   @db.VarChar(255)
  line2      String?  @db.VarChar(255)
  city       String   @db.VarChar(100)
  province   String   @db.VarChar(100)
  postalCode String   @db.VarChar(20)
  country    String   @default("AR") @db.VarChar(2)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── CATALOG ──────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId    String   @db.VarChar(26)
  storeId     String   @db.VarChar(26)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  slug        String   @db.VarChar(255)
  isActive    Boolean  @default(true)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  store      Store           @relation(fields: [storeId], references: [id])
  variants   Variant[]
  categories ProductCategory[]
  collections ProductCollection[]
  stock      Stock[]
  auditLogs  AuditLog[]

  @@unique([storeId, slug])
  @@index([tenantId])
  @@index([storeId])
}

model Variant {
  id          String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  productId   String   @db.VarChar(26)
  tenantId    String   @db.VarChar(26)
  storeId     String   @db.VarChar(26)
  sku         String   @db.VarChar(100)
  name        String   @db.VarChar(255)
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("ARS") @db.VarChar(3)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  costPrice   Decimal? @db.Decimal(12, 2)
  weight      Decimal? @db.Decimal(8, 2)
  weightUnit  String?  @default("g") @db.VarChar(5)
  dimensions  Json?    @default("{}")
  barcode     String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock   Stock[]

  @@unique([storeId, sku])
  @@index([tenantId])
  @@index([storeId])
  @@index([productId])
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId  String   @db.VarChar(26)
  storeId   String   @db.VarChar(26)
  parentId  String?  @db.VarChar(26)
  name      String   @db.VarChar(255)
  slug      String   @db.VarChar(255)
  description String? @db.Text
  imageUrl  String?  @db.VarChar(500)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  parent   Category?        @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]       @relation("CategoryTree")
  products ProductCategory[]

  @@unique([storeId, slug])
  @@index([tenantId])
  @@index([storeId])
  @@index([parentId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model Collection {
  id          String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId    String   @db.VarChar(26)
  storeId     String   @db.VarChar(26)
  name        String   @db.VarChar(255)
  slug        String   @db.VarChar(255)
  description String?  @db.Text
  imageUrl    String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  products ProductCollection[]

  @@unique([storeId, slug])
  @@index([tenantId])
  @@index([storeId])
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────

model Stock {
  id              String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  variantId       String   @db.VarChar(26)
  productId       String   @db.VarChar(26)
  tenantId        String   @db.VarChar(26)
  storeId         String   @db.VarChar(26)
  available       Int      @default(0)
  reserved        Int      @default(0)
  lowStockThreshold Int?   @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variant  Variant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  logs     StockAdjustment[]

  @@unique([variantId, storeId])
  @@index([tenantId])
  @@index([storeId])
  @@index([productId])
}

model StockAdjustment {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  stockId   String   @db.VarChar(26)
  variantId String   @db.VarChar(26)
  storeId   String   @db.VarChar(26)
  type      String   @db.VarChar(20)
  quantity  Int
  reason    String   @db.VarChar(255)
  referenceId String? @db.VarChar(26)
  createdAt DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
  @@index([variantId])
  @@index([storeId])
}

// ─── CART ─────────────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId   String   @db.VarChar(26)
  storeId    String   @db.VarChar(26)
  customerId String?  @db.VarChar(26)
  guestToken String?  @db.VarChar(255)
  couponCode String?  @db.VarChar(100)
  currency   String   @default("ARS") @db.VarChar(3)
  subtotal   Decimal  @default(0) @db.Decimal(12, 2)
  discount   Decimal  @default(0) @db.Decimal(12, 2)
  shipping   Decimal  @default(0) @db.Decimal(12, 2)
  total      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store     Store      @relation(fields: [storeId], references: [id])
  customer  Customer?  @relation(fields: [customerId], references: [id])
  items     CartItem[]

  @@unique([storeId, guestToken])
  @@unique([storeId, customerId])
  @@index([tenantId])
  @@index([storeId])
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  cartId    String   @db.VarChar(26)
  variantId String   @db.VarChar(26)
  productId String   @db.VarChar(26)
  storeId   String   @db.VarChar(26)
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([variantId])
}

// ─── ORDER ────────────────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId      String      @db.VarChar(26)
  storeId       String      @db.VarChar(26)
  customerId    String?     @db.VarChar(26)
  orderNumber   Int
  status        OrderStatus @default(PENDING_PAYMENT)
  currency      String      @default("ARS") @db.VarChar(3)
  subtotal      Decimal     @db.Decimal(12, 2)
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  shipping      Decimal     @default(0) @db.Decimal(12, 2)
  tax           Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  couponCode    String?     @db.VarChar(100)
  notes         String?     @db.Text
  metadata      Json        @default("{}")
  snapshot      Json        @default("{}")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  store         Store              @relation(fields: [storeId], references: [id])
  customer      Customer?          @relation(fields: [customerId], references: [id])
  items         OrderItem[]
  paymentSessions PaymentSession[]
  auditLogs     AuditLog[]

  @@unique([storeId, orderNumber])
  @@index([tenantId])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  orderId     String  @db.VarChar(26)
  variantId   String  @db.VarChar(26)
  productId   String  @db.VarChar(26)
  storeId     String  @db.VarChar(26)
  productName String  @db.VarChar(255)
  variantName String  @db.VarChar(255)
  sku         String  @db.VarChar(100)
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  metadata    Json    @default("{}")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────

model PaymentProvider {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId  String   @db.VarChar(26)
  storeId   String   @db.VarChar(26)
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(50)
  isActive  Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessions PaymentSession[]

  @@unique([storeId, code])
  @@index([tenantId])
  @@index([storeId])
}

model PaymentSession {
  id              String        @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  orderId         String        @db.VarChar(26)
  storeId         String        @db.VarChar(26)
  providerId      String        @db.VarChar(26)
  providerSessionId String?      @db.VarChar(255)
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("ARS") @db.VarChar(3)
  idempotencyKey  String?       @unique @db.VarChar(255)
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order    Order           @relation(fields: [orderId], references: [id])
  provider PaymentProvider @relation(fields: [providerId], references: [id])

  @@index([orderId])
  @@index([storeId])
}

// ─── SHIPPING ─────────────────────────────────────────────────────────────────

model ShippingMethod {
  id           String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId     String   @db.VarChar(26)
  storeId      String   @db.VarChar(26)
  name         String   @db.VarChar(255)
  type         String   @db.VarChar(50)
  cost         Decimal? @db.Decimal(12, 2)
  freeOver     Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  config       Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  store Store @relation(fields: [storeId], references: [id])
  zones ShippingZone[]

  @@index([tenantId])
  @@index([storeId])
}

model ShippingZone {
  id               String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  shippingMethodId String   @db.VarChar(26)
  name             String   @db.VarChar(255)
  countries        String[] @db.VarChar(2)
  provinces        String[] @db.VarChar(100)
  postalCodes      String?  @db.VarChar(500)
  cost             Decimal? @db.Decimal(12, 2)
  freeOver         Decimal? @db.Decimal(12, 2)
  estimatedDaysMin Int?
  estimatedDaysMax Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  storeId String @db.VarChar(26)
  store   Store  @relation(fields: [storeId], references: [id])

  method ShippingMethod @relation(fields: [shippingMethodId], references: [id], onDelete: Cascade)

  @@index([shippingMethodId])
  @@index([storeId])
}

// ─── PROMOTION ────────────────────────────────────────────────────────────────

model Promotion {
  id              String        @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId        String        @db.VarChar(26)
  storeId         String        @db.VarChar(26)
  name            String        @db.VarChar(255)
  type            PromotionType
  config          Json          @default("{}")
  startsAt        DateTime
  endsAt          DateTime?
  minQuantity     Int?
  minCartAmount   Decimal?      @db.Decimal(12, 2)
  targetProductId String?       @db.VarChar(26)
  targetCategoryId String?      @db.VarChar(26)
  targetPaymentMethod String?   @db.VarChar(50)
  isActive        Boolean       @default(true)
  maxUsage        Int?
  currentUsage    Int           @default(0)
  priority        Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  store  Store @relation(fields: [storeId], references: [id])
  coupons  Coupon[]
  usages   PromotionUsage[]

  @@index([tenantId])
  @@index([storeId])
  @@index([type])
}

model Coupon {
  id            String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  promotionId   String   @db.VarChar(26)
  tenantId      String   @db.VarChar(26)
  storeId       String   @db.VarChar(26)
  code          String   @db.VarChar(100)
  maxUsage      Int?
  currentUsage  Int      @default(0)
  maxPerCustomer Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  store     Store     @relation(fields: [storeId], references: [id])
  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
  @@index([tenantId])
  @@index([storeId])
}

model PromotionUsage {
  id          String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  promotionId String   @db.VarChar(26)
  couponId    String?  @db.VarChar(26)
  orderId     String?  @db.VarChar(26)
  customerId  String?  @db.VarChar(26)
  tenantId    String   @db.VarChar(26)
  storeId     String   @db.VarChar(26)
  discount    Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([storeId])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId   String   @db.VarChar(26)
  storeId    String?  @db.VarChar(26)
  adminId    String?  @db.VarChar(26)
  customerId String?  @db.VarChar(26)
  entityType String   @db.VarChar(100)
  entityId   String   @db.VarChar(26)
  action     String   @db.VarChar(100)
  oldValue   Json?
  newValue   Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  productId  String?  @db.VarChar(26)
  orderId    String?  @db.VarChar(26)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  store   Store?   @relation(fields: [storeId], references: [id])
  admin   Admin?   @relation(fields: [adminId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([storeId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([productId])
  @@index([orderId])
}

// ─── WEBHOOK ──────────────────────────────────────────────────────────────────

model WebhookEndpoint {
  id            String        @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId      String        @db.VarChar(26)
  storeId       String        @db.VarChar(26)
  url           String        @db.VarChar(500)
  secret        String        @db.VarChar(255)
  events        WebhookEvent[]
  isActive      Boolean       @default(true)
  retryCount    Int           @default(3)
  timeoutMs     Int           @default(5000)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  store     Store            @relation(fields: [storeId], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@index([storeId])
}

model WebhookDelivery {
  id          String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  endpointId  String   @db.VarChar(26)
  eventId     String   @db.VarChar(26)
  eventType   String   @db.VarChar(100)
  payload     Json
  response    Json?
  statusCode  Int?
  status      String   @default("pending") @db.VarChar(20)
  attempt     Int      @default(1)
  durationMs  Int?
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([eventId])
  @@index([status])
}

// ─── NOTIFICATION ─────────────────────────────────────────────────────────────

model NotificationTemplate {
  id        String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId  String   @db.VarChar(26)
  storeId   String   @db.VarChar(26)
  type      String   @db.VarChar(100)
  subject   String   @db.VarChar(255)
  body      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, type])
  @@index([tenantId])
  @@index([storeId])
}

model NotificationLog {
  id         String   @id @default(dbgenerated("gen_random_ulid()")) @db.VarChar(26)
  tenantId   String   @db.VarChar(26)
  storeId    String   @db.VarChar(26)
  templateId String?  @db.VarChar(26)
  to         String   @db.VarChar(255)
  type       String   @db.VarChar(100)
  subject    String   @db.VarChar(255)
  status     String   @default("sent") @db.VarChar(20)
  error      String?  @db.Text
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([storeId])
  @@index([type])
  @@index([createdAt])
}
